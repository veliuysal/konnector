#!/bin/sh
set -eu

SERVICE=konnector.service

case "${1}" in
  remove|upgrade|deconfigure)
    if systemctl is-active --quiet "${SERVICE}" 2>/dev/null; then
      systemctl stop "${SERVICE}" || true
    fi
    ;;
  failed-upgrade)
    ;;
  *)
    echo "prerm called with unknown argument: ${1}" >&2
    exit 1
    ;;
esac

#DEBHELPER#

exit 0
