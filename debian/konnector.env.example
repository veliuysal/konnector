# Copy to /etc/konnector.env and adjust for the server.
# The konnector systemd service loads this file automatically.
# Every variable has a built-in default; set only what you want to override.

# Runtime (defaults: THREADS=CPU cores max 4, HTTP=0.0.0.0:80, HTTPS=0.0.0.0:443)
# THREADS=4
# HTTP_LISTEN=0.0.0.0:80
# HTTPS_LISTEN=0.0.0.0:443

# Paths (defaults shown)
# CONFIG_DIR=/opt/konnector/current/configs
# LOGS_DIR=/etc/konnector/logs
# TLS_DIR=/etc/ssl/konnector

# Optional root proxy override when no site matches.
# ROOT_PROXY=127.0.0.1:3000
# ROOT_PROXY_TLS=false
# ROOT_PROXY_SNI=
# ROOT_PROXY_HOST=
# ROOT_PROXY_CA_PATH=

# TLS (defaults: TLS_ENABLED=false, TLS_PROVIDER=acme when tls.auto, else none,
# TLS_CHECK_INTERVAL_SECONDS=21600, ACME_STAGING=false / from root.yaml)
# TLS_ENABLED=false
# TLS_PROVIDER=acme
# ACME_STAGING=false
# TLS_CHECK_INTERVAL_SECONDS=21600

# Cloudflare Origin CA (only when TLS_PROVIDER=cloudflare)
# CLOUDFLARE_API_TOKEN=

# Custom cert fetch (only when TLS_PROVIDER=command)
# TLS_FETCH_COMMAND=
