# Copy to /etc/konnector.env and adjust for the server.
# The konnector systemd service loads this file automatically.

# Runtime
THREADS=4
HTTP_LISTEN=0.0.0.0:80
HTTPS_LISTEN=0.0.0.0:443

# Site configs bundled with each release.
CONFIG_DIR=/opt/konnector/current/configs

# Optional root proxy override when no site matches.
# Default comes from configs/root.yaml in the release bundle.
# ROOT_PROXY=127.0.0.1:3000
# ROOT_PROXY_TLS=false

# HTTPS termination on the origin server.
# TLS_ENABLED=true
# TLS_CERT_PATH=/etc/ssl/konnector/fullchain.pem
# TLS_KEY_PATH=/etc/ssl/konnector/privkey.pem
# TLS_PROVIDER=cloudflare
# CLOUDFLARE_API_TOKEN=
# TLS_CHECK_INTERVAL_SECONDS=21600
