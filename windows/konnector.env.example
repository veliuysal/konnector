# Every variable has a built-in default; set only what you want to override.

# Runtime
# THREADS=4
# HTTP_LISTEN=0.0.0.0:80
# HTTPS_LISTEN=0.0.0.0:443

# Paths (defaults shown)
# CONFIG_DIR=C:\ProgramData\Konnector\configs
# LOGS_DIR=C:\ProgramData\Konnector\logs
# TLS_DIR=C:\ProgramData\Konnector\ssl

# Optional root proxy override
# ROOT_PROXY=127.0.0.1:3000
# ROOT_PROXY_TLS=false

# TLS — HTTPS on by default; cert source auto (CF token → Origin CA, else Let's Encrypt)
# TLS_ENABLED=false
# ACME_STAGING=false
# TLS_CHECK_INTERVAL_SECONDS=21600
# CLOUDFLARE_API_TOKEN=
# TLS_FETCH_COMMAND=
